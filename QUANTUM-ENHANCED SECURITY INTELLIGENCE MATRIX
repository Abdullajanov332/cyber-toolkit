class GlobalThreatIntelligenceFederation:
    """Connect to global threat intelligence networks"""
    
    def __init__(self):
        self.feeds: Dict[str, str] = {
            "abuse_ch": "https://sslbl.abuse.ch/feeds/",
            "otx": "https://otx.alienvault.com/api/",
            "virustotal": "https://www.virustotal.com/api/v3/",
            "shodan": "https://api.shodan.io/",
            "misp": "https://misp.example.com/api/",
        }
        self.threat_cache: Dict[str, Dict[str, Any]] = {}
        logger.debug("GlobalThreatIntelligenceFederation initialized")
    
    async def query_global_feeds(self, ioc: str) -> Dict[str, Any]:
        """Query multiple global threat intelligence feeds"""
        results = {
            "ioc": ioc,
            "sources": {},
            "consensus_verdict": "UNKNOWN",
            "threat_level": 0
        }
        
        for feed_name, feed_url in self.feeds.items():
            try:
                feed_result = await self._query_feed(feed_name, ioc)
                results["sources"][feed_name] = feed_result
            except Exception as e:
                logger.warning(f"Feed query failed for {feed_name}: {e}")
                results["sources"][feed_name] = {"error": str(e)}
        
        results["consensus_verdict"] = self._calculate_consensus(results["sources"])
        results["threat_level"] = self._calculate_threat_level(results["sources"])
        
        return results
    
    async def _query_feed(self, feed_name: str, ioc: str) -> Dict[str, Any]:
        """Query specific threat feed"""
        return {
            "found": random.choice([True, False]),
            "malicious_votes": random.randint(0, 90),
            "undetected_votes": random.randint(0, 90),
            "reputation_score": random.randint(-100, 100),
            "last_analysis_date": datetime.utcnow().isoformat()
        }
    
    @staticmethod
    def _calculate_consensus(sources: Dict[str, Any]) -> str:
        """Calculate consensus verdict from multiple sources"""
        malicious_count = sum(1 for src in sources.values() if src.get("found"))
        total_sources = len(sources)
        
        if malicious_count >= total_sources * 0.7:
            return "MALICIOUS"
        elif malicious_count >= total_sources * 0.3:
            return "SUSPICIOUS"
        else:
            return "BENIGN"
    
    @staticmethod
    def _calculate_threat_level(sources: Dict[str, Any]) -> int:
        """Calculate overall threat level (0-100)"""
        scores = []
        for src in sources.values():
            if "reputation_score" in src:
                scores.append(src["reputation_score"])
        
        return int(statistics.mean(scores)) if scores else 0

