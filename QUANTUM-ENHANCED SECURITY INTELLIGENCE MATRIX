class BlockchainAuditTrail:
    """Immutable blockchain-based audit trail"""
    
    def __init__(self, chain_db: Path):
        self.chain_db = chain_db
        self.blocks: List[Dict[str, Any]] = []
        self.merkle_tree: List[str] = []
        self.crypto = QuantumResistantCryptography()
        self._init_blockchain()
        logger.debug("BlockchainAuditTrail initialized")
    
    def _init_blockchain(self):
        """Initialize blockchain"""
        try:
            conn = sqlite3.connect(self.chain_db)
            cursor = conn.cursor()
            
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS blockchain_ledger (
                    block_index INTEGER PRIMARY KEY,
                    block_hash TEXT UNIQUE,
                    previous_hash TEXT,
                    timestamp TIMESTAMP,
                    events_json TEXT,
                    merkle_root TEXT,
                    nonce INTEGER,
                    miner_signature TEXT
                )
            ''')
            
            conn.commit()
            conn.close()
            logger.debug("Blockchain database initialized")
        except Exception as e:
            logger.error(f"Blockchain initialization failed: {e}")
    
    async def add_events_to_chain(self, events: List[Dict[str, Any]]) -> Dict[str, Any]:
        """Add events to blockchain with proof of work"""
        
        block_index = len(self.blocks)
        previous_hash = self.blocks[-1]['block_hash'] if self.blocks else "0"*64
        timestamp = datetime.utcnow().isoformat()
        
        event_hashes = [
            hashlib.sha256(json.dumps(e, sort_keys=True).encode()).hexdigest()
            for e in events
        ]
        merkle_root = self._calculate_merkle_root(event_hashes)
        
        nonce = await self._proof_of_work(block_index, previous_hash, merkle_root)
        
        block_data = json.dumps(events, sort_keys=True)
        block_string = f"{block_index}{previous_hash}{timestamp}{block_data}{merkle_root}{nonce}"
        block_hash = hashlib.sha256(block_string.encode()).hexdigest()
        
        signature = self.crypto.create_hmac_signature(block_hash)
        
        block = {
            "block_index": block_index,
            "block_hash": block_hash,
            "previous_hash": previous_hash,
            "timestamp": timestamp,
            "events": events,
            "merkle_root": merkle_root,
            "nonce": nonce,
            "signature": signature
        }
        
        self.blocks.append(block)
        
        try:
            conn = sqlite3.connect(self.chain_db)
            cursor = conn.cursor()
            cursor.execute('''
                INSERT INTO blockchain_ledger 
                (block_index, block_hash, previous_hash, timestamp, events_json, merkle_root, nonce, miner_signature)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            ''', (block_index, block_hash, previous_hash, timestamp, block_data, merkle_root, nonce, signature))
            conn.commit()
            conn.close()
            logger.debug(f"Block {block_index} added to blockchain")
        except Exception as e:
            logger.error(f"Block insertion failed: {e}")
        
        return block
    
    async def _proof_of_work(self, block_index: int, previous_hash: str, merkle_root: str) -> int:
        """Calculate proof of work"""
        nonce = 0
        
        while True:
            candidate_hash = hashlib.sha256(
                f"{block_index}{previous_hash}{merkle_root}{nonce}".encode()
            ).hexdigest()
            
            if candidate_hash.startswith("00"):
                return nonce
            
            nonce += 1
            
            if nonce % 10000 == 0:
                await asyncio.sleep(0)
    
    @staticmethod
    def _calculate_merkle_root(hashes: List[str]) -> str:
        """Calculate merkle root"""
        if not hashes:
            return hashlib.sha256(b"").hexdigest()
        
        if len(hashes) == 1:
            return hashes[0]
        
        if len(hashes) % 2 != 0:
            hashes.append(hashes[-1])
        
        parent_hashes = []
        for i in range(0, len(hashes), 2):
            combined = hashes[i] + hashes[i+1]
            parent_hash = hashlib.sha256(combined.encode()).hexdigest()
            parent_hashes.append(parent_hash)
        
        return BlockchainAuditTrail._calculate_merkle_root(parent_hashes)

