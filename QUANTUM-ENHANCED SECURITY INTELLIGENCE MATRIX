        return {
            "openssl": "1.1.1",
            "libpq": "12.1",
            "python": "3.9.1",
            "nodejs": "14.15.0"
        }
    
    @staticmethod
    def _assess_cve_severity(cve: str) -> str:
        """Assess CVE severity"""
        cve_scores = {
            "CVE-2016-2107": "CRITICAL",
            "CVE-2017-3735": "HIGH",
            "CVE-2021-3711": "HIGH",
            "CVE-2021-23214": "CRITICAL",
            "CVE-2021-23222": "CRITICAL",
            "CVE-2020-8287": "MEDIUM",
            "CVE-2021-3426": "MEDIUM",
            "CVE-2021-21285": "CRITICAL",
        }
        return cve_scores.get(cve, "UNKNOWN")

