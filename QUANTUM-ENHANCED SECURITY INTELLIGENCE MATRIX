    def scan_container_image(self, image_name: str, image_layers: List[str]) -> Dict[str, Any]:
        """Scan container image for vulnerabilities"""
        vulnerabilities = []
        critical_count = 0
        
        for layer in image_layers:
            packages = self._extract_packages_from_layer(layer)
            
            for pkg_name, pkg_version in packages.items():
                if pkg_name in self.vulnerability_db:
                    for cve in self.vulnerability_db[pkg_name]:
                        vulnerabilities.append({
                            "package": pkg_name,
                            "version": pkg_version,
                            "cve": cve,
                            "severity": self._assess_cve_severity(cve),
                            "layer": layer
                        })
                        if self._assess_cve_severity(cve) == "CRITICAL":
                            critical_count += 1
        
        logger.debug(f"Container scan completed for {image_name}: {len(vulnerabilities)} vulnerabilities found")
        
        return {
            "image": image_name,
            "total_vulnerabilities": len(vulnerabilities),
            "critical_vulnerabilities": critical_count,
            "vulnerabilities": vulnerabilities,
            "overall_risk": "CRITICAL" if critical_count > 0 else "HIGH" if len(vulnerabilities) > 5 else "MEDIUM"
        }
    
    @staticmethod
    def _extract_packages_from_layer(layer: str) -> Dict[str, str]:
