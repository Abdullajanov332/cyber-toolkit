class AnomalyDetectionEngine:
    """Detect anomalies in data streams"""
    
    def __init__(self):
        self.baseline_stats = {
            "avg_event_size": 0,
            "avg_frequency": 0,
            "std_dev": 0
        }
        logger.debug("AnomalyDetectionEngine initialized")
    
    async def detect_anomalies(self, events: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """Detect anomalies in event batch"""
        anomalies = []
        
        if not events:
            return anomalies
        
        sizes = [e.get('size', 0) for e in events]
        mean_size = statistics.mean(sizes)
        
        try:
            std_dev = statistics.stdev(sizes) if len(sizes) > 1 else 0
        except:
            std_dev = 0
        
        for event in events:
            size = event.get('size', 0)
            if std_dev > 0:
                z_score = abs((size - mean_size) / std_dev)
                if z_score > 3:
                    anomalies.append({
                        "event": event,
                        "anomaly_type": "SIZE_OUTLIER",
                        "z_score": z_score
                    })
        
        return anomalies

class StreamingDataProcessor:
    """Process high-velocity security data streams"""
    
    def __init__(self, batch_size: int = 1000, processing_window: int = 60):
        self.batch_size = batch_size
        self.processing_window = processing_window
        self.event_buffer = deque(maxlen=10000)
        self.anomaly_detector = AnomalyDetectionEngine()
        logger.debug("StreamingDataProcessor initialized")
    
    async def process_data_stream(self, data_source: Generator[str, None, None]) -> Dict[str, Any]:
        """Process continuous data stream"""
        
        start_time = time.time()
        batch = []
        statistics_collection = {
            "events_processed": 0,
            "anomalies_detected": 0,
            "average_latency_ms": 0,
            "throughput_events_per_sec": 0
        }
        
        latencies = []
        
        for raw_data in data_source:
            process_start = time.perf_counter()
            
            event = self._parse_stream_event(raw_data)
            if event:
                batch.append(event)
                self.event_buffer.append(event)
            
            if len(batch) >= self.batch_size:
                anomalies = await self.anomaly_detector.detect_anomalies(batch)
                statistics_collection["anomalies_detected"] += len(anomalies)
                batch = []
            
            latency_ms = (time.perf_counter() - process_start) * 1000
            latencies.append(latency_ms)
            
            statistics_collection["events_processed"] += 1
            
            if statistics_collection["events_processed"] % 1000 == 0:
                statistics_collection["average_latency_ms"] = statistics.mean(latencies[-1000:])
                elapsed = time.time() - start_time
                statistics_collection["throughput_events_per_sec"] = (
                    statistics_collection["events_processed"] / elapsed
                )
        
        return statistics_collection
    
    @staticmethod
    def _parse_stream_event(raw_data: str) -> Optional[Dict[str, Any]]:
        """Parse streaming event"""
        try:
            timestamp = datetime.utcnow().isoformat()
            return {
                "timestamp": timestamp,
                "raw_data": raw_data,
                "size": len(raw_data)
            }
        except:
            return None

